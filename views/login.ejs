<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= settings.appName %> - Login</title>
  <link rel="stylesheet" href="/static/style.css">
  <style>
    body::before{
      background-image: linear-gradient(rgba(11,7,20,.70), rgba(11,7,20,.86)), url('<%= settings.backgroundImageUrl || "/static/default-bg.svg" %>');
      filter: blur(<%= settings.blurStrength || 14 %>px);
      transform: scale(1.06);
    }
  </style>
</head>
<body class="login-page">
  <div class="overlay"></div>
  <div class="login-card glass fx-float">
    <div class="login-inner">
      <div class="brand-wrap">
        <div class="top-badge pulse">WM STORE PANEL</div>
        <img src="<%= logoPath() %>" class="brand-logo glow" alt="WM STORE Logo">
        <h1 class="brand-title"><%= settings.appName %></h1>
        <p class="brand-desc"><%= settings.siteDescription %></p>
      </div>
      <div class="developer-box hover-lift">
        <img src="<%= developer.avatar %>" class="developer-avatar ring" alt="Developer">
        <div class="developer-meta">
          <span class="developer-label">Developer</span>
          <span class="developer-name"><%= developer.displayName %></span>
          <span class="developer-user">@<%= developer.username %></span>
        </div>
      </div>
      <% if (error) { %><div class="alert error"><%= error %></div><% } %>
      <form method="POST" action="/login">
        <div class="field"><label>الإيميل</label><input type="email" name="email" required value="alaaijaj34@gmail.com"></div>
        <div class="field"><label>كلمة المرور</label><input type="password" name="password" required value="ali2005"></div>
        <button class="primary-btn full-btn shine-btn" type="submit">دخول</button>
      </form>
    </div>
  </div>
</body>
</html>
